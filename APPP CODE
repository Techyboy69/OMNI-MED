                } else if (!anyCritical && isAlarming) {
                    isAlarming = false; document.getElementById('critical_overlay').style.display = "none"; stopSiren();
                }

                // CHAT
                if(data.chats.length !== lastCounts.chat) {
                    let chatHTML = "";
