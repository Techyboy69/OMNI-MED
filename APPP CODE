# ==================== ROBUST AUDIO ENGINE ====================
def voice_recognition_worker():
    recognizer = sr.Recognizer()
    mic = sr.Microphone()
    crisis_words = {
        "help": "NURSE_CALL", "nurse": "NURSE_CALL", 
        "heart": "CARDIAC_ARREST", "chest": "CARDIAC_ARREST", 
        "chok": "CHOKE_ALERT", "breathe": "CHOKE_ALERT"
    }
    
    print("[AUDIO CORE] Calibrating Microphone...")
    try:
        with mic as source: recognizer.adjust_for_ambient_noise(source, duration=2)
        print("[AUDIO CORE] Microphone Actively Listening.")
    except Exception: return

    while is_system_running:
        try:
            with mic as source: audio = recognizer.listen(source, timeout=1, phrase_time_limit=4)
            text = recognizer.recognize_google(audio).lower()
            
            with database_lock:
                CHAT_MESSAGES.append({"time": time.strftime('%H:%M:%S'), "sender": "AUDIO_AI", "target": "ALL", "msg": f"Voice Detected: '{text}'"})
                LATEST_EVENTS["chat"] += 1
            
            for word, category in crisis_words.items():
                if word in text:
                    with database_lock:
                        if not LIVE_TRIAGE_ALARMS[category]["active"]:
                            LIVE_TRIAGE_ALARMS[category]["active"] = True
                            LIVE_TRIAGE_ALARMS[category]["acknowledged"] = False
                            LATEST_EVENTS["alarm"] += 1
                    break
        except Exception: pass

