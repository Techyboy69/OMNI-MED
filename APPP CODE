                // NURSE
                if(currentRole === "REGISTERED_NURSE") {
                    let n_html = data.nurse_tasks.length === 0 ? `<div style="color:var(--text-muted); font-size:12px;">No pending tasks.</div>` : "";
                    data.nurse_tasks.forEach((t, i) => {
                        n_html += `<div class="list-card nurse-task"><div style="color:var(--green); font-weight:800; font-size:14px;">ADMINISTER: ${t.qty}x ${t.med}</div><div style="font-size:10px; color:var(--text-muted); margin-top:5px;">Ordered by: ${t.doctor.replace('_', ' ')}</div><button class="btn-full" style="background:var(--green); color:#000;" onclick="completeNurseTask(${i})">Mark Administered</button></div>`;
