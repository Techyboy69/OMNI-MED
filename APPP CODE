                            let tTag = (c.target !== "ALL" && c.sender !== "SYSTEM" && c.sender !== "AUDIO_AI") ? `<span class="target-tag">[@${c.target.replace('_', ' ')}]</span><br>` : "";
                            chatHTML += `<div class="${wrapClass}"><div class="msg-sender">${senderName} • ${c.time}</div><div class="msg-bubble">${tTag}${c.msg}</div></div>`;
                        }
                    });
                    let chatBox = document.getElementById('chat_messages');
                    chatBox.innerHTML = chatHTML;
                    // Auto-scroll fix
                    setTimeout(() => { chatBox.scrollTop = chatBox.scrollHeight; }, 50);
                    if(lastCounts.chat !== 0 && data.chats[data.chats.length-1].sender !== currentRole) playChime('msg');
                    lastCounts.chat = data.chats.length;
                }

                // TOASTS
                if(data.events.pharmacy > lastCounts.pharmacy) {
                    if(currentRole === "HEAD_PHARMACIST") showToast("New ER Prescription Received!", "danger");
                    playChime('alarm'); lastCounts.pharmacy = data.events.pharmacy;
                }

                // PHARMACY
                if(currentRole === "HEAD_PHARMACIST") {
                    let p_html = data.pharmacy.length === 0 ? `<div style="color:var(--text-muted); font-size:12px;">No active prescriptions.</div>` : "";
                    data.pharmacy.forEach((p, i) => {
